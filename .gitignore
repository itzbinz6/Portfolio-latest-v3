# dependencies
node_modules

# build output
dist
dist-ssr

# TypeScript incremental build cache — this is a local artifact tied to
# your machine's file timestamps; committing it can confuse `tsc -b` on
# a fresh CI/Vercel checkout
tsconfig.tsbuildinfo
*.tsbuildinfo

# env files — never commit secrets
.env
.env.local
.env.*.local

# editor/OS
.vscode/*
!.vscode/extensions.json
.DS_Store
*.log
npm-debug.log*
